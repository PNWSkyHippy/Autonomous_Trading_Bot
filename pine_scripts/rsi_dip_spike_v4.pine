//@version=5
strategy("RSI Dip and Spike v4c", shorttitle="RSI-DS-v4c", overlay=true, pyramiding=0, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=10, commission_type=strategy.commission.percent, commission_value=0.05, currency=currency.USD)

// ─── Inputs ───────────────────────────────────────────────
rsi_length     = input.int(7,     title="RSI Length",                group="RSI Settings", minval=1)
rsi_oversold   = input.float(35.0, title="RSI Oversold Level",       group="RSI Settings", step=0.5)
rsi_overbought = input.float(80.0, title="RSI Overbought Level",     group="RSI Settings", step=0.5)
rsi_exit_long  = input.float(55.0, title="RSI Exit Long",            group="RSI Settings", step=0.5)
rsi_exit_short = input.float(45.0, title="RSI Exit Short",           group="RSI Settings", step=0.5)
signal_mode    = input.string("penetration", title="Signal Mode",    group="RSI Settings", options=["penetration", "reclaim"])

trend_ma_length = input.int(200,  title="Trend SMA Length",          group="Trend Filter", minval=10)

adx_length     = input.int(14,    title="ADX Length",                group="ADX Filter", minval=1)
adx_min        = input.float(25.0, title="ADX Minimum",              group="ADX Filter", step=0.5)
adx_max        = input.float(60.0, title="ADX Maximum",              group="ADX Filter", step=0.5)

atr_length     = input.int(14,    title="ATR Length",                group="ATR Stop and Target", minval=1)
sl_atr_mult    = input.float(2.5, title="Stop Loss ATR Multiplier",  group="ATR Stop and Target", step=0.1)
tp_atr_mult    = input.float(2.0, title="Take Profit ATR Multiplier",group="ATR Stop and Target", step=0.1)

max_bars_hold  = input.int(48,    title="Max Bars in Trade",         group="Trade Settings", minval=1)
trade_longs    = input.bool(true,  title="Enable Long Trades",       group="Trade Settings")
trade_shorts   = input.bool(false, title="Enable Short Trades",      group="Trade Settings")

// ─── Indicators ───────────────────────────────────────────
rsi      = ta.rsi(close, rsi_length)
macro_ma = ta.sma(close, trend_ma_length)
atr      = ta.atr(atr_length)
[diplus, diminus, adx_val] = ta.dmi(adx_length, adx_length)

// ─── Filters ──────────────────────────────────────────────
bull_regime = close > macro_ma
bear_regime = close < macro_ma
adx_ok      = adx_val >= adx_min and adx_val <= adx_max

// ─── Signals ──────────────────────────────────────────────
long_cross  = signal_mode == "penetration" ? ta.crossunder(rsi, rsi_oversold)  : ta.crossover(rsi, rsi_oversold)
short_cross = signal_mode == "penetration" ? ta.crossover(rsi, rsi_overbought) : ta.crossunder(rsi, rsi_overbought)

long_signal  = long_cross  and bull_regime and adx_ok and trade_longs
short_signal = short_cross and bear_regime and adx_ok and trade_shorts

// ─── Entries ──────────────────────────────────────────────
var float long_sl  = na
var float long_tp  = na
var float short_sl = na
var float short_tp = na

if long_signal and strategy.position_size == 0
    long_sl := close - atr * sl_atr_mult
    long_tp := close + atr * tp_atr_mult
    strategy.entry("Long", strategy.long)
    strategy.exit("LX", "Long", stop=long_sl, limit=long_tp)

if short_signal and strategy.position_size == 0
    short_sl := close + atr * sl_atr_mult
    short_tp := close - atr * tp_atr_mult
    strategy.entry("Short", strategy.short)
    strategy.exit("SX", "Short", stop=short_sl, limit=short_tp)

// RSI neutral exit
if strategy.position_size > 0 and ta.crossover(rsi, rsi_exit_long)
    strategy.close("Long", comment="RSI exit")

if strategy.position_size < 0 and ta.crossunder(rsi, rsi_exit_short)
    strategy.close("Short", comment="RSI exit")

// Time limit
if strategy.position_size != 0 and ta.barssince(strategy.position_size[1] == 0) >= max_bars_hold
    strategy.close_all(comment="Time limit")

// ─── Plots ────────────────────────────────────────────────
plot(macro_ma, title="SMA 200", color=color.new(color.yellow, 40), linewidth=1)

plotshape(long_signal,  title="Long",  style=shape.triangleup,   location=location.belowbar, color=color.lime, size=size.small)
plotshape(short_signal, title="Short", style=shape.triangledown, location=location.abovebar, color=color.red,  size=size.small)

plot(strategy.position_size > 0 ? long_sl  : na, title="Long SL",  color=color.red,   style=plot.style_linebr)
plot(strategy.position_size > 0 ? long_tp  : na, title="Long TP",  color=color.green, style=plot.style_linebr)
plot(strategy.position_size < 0 ? short_sl : na, title="Short SL", color=color.red,   style=plot.style_linebr)
plot(strategy.position_size < 0 ? short_tp : na, title="Short TP", color=color.green, style=plot.style_linebr)

bgcolor(bull_regime ? color.new(color.green, 97) : color.new(color.red, 97))
