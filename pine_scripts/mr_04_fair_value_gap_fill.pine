//@version=5
// ─────────────────────────────────────────────────────────────────────────────
// MR-04  Fair Value Gap Fill
// ─────────────────────────────────────────────────────────────────────────────
// Hypothesis:
//   A Fair Value Gap (FVG) is created when bar[1] moves so aggressively that
//   there is a price gap between bar[2].high and bar[0].low (bullish FVG) or
//   bar[2].low and bar[0].high (bearish FVG). These gaps represent imbalanced
//   price action — one side had no opposition. Price has a statistical tendency
//   to return and "fill" these zones.
//
// Why this is NOT a retail strategy:
//   Based on structural market microstructure (order imbalance), not an
//   indicator. The FVG zone has a mechanically defined entry, stop, and TP.
//   Most traders use this discretionarily; this version is fully systematic.
//
// Edge: Imbalanced price action leaves unfilled orders. Market makers and
//       algorithmic participants tend to revisit these zones.
//
// Note: ATR minimum size filter prevents trading micro-gaps that are just noise.
// ─────────────────────────────────────────────────────────────────────────────
strategy("MR-04 Fair Value Gap Fill", shorttitle="MR-04 FVG", overlay=true,
         default_qty_type  = strategy.percent_of_equity,
         default_qty_value = 10,
         commission_type   = strategy.commission.percent,
         commission_value  = 0.05,
         slippage          = 2)

// ── Inputs ────────────────────────────────────────────────────────────────────
int   atrLen      = input.int  (14,   "ATR Period",                   minval=5,  group="FVG")
float minGapAtr = input.float(0.3, "Min Gap Size (x ATR)", minval=0.0, maxval=2.0, step=0.05, group="FVG")
int   lookback    = input.int  (50,   "Max Bars Before Gap Expires",  minval=5,  group="FVG")
int   adxLen      = input.int  (14,   "ADX Period",                   minval=5,  group="Regime")
float adxMax      = input.float(35,   "ADX Max (not in strong trend)", step=1.0, group="Regime")
float slMult      = input.float(1.0,  "SL Gap Multiplier",            step=0.1,  group="Risk")
int   maxBars     = input.int  (48,   "Max Bars to Hold (time stop)", minval=1,  group="Risk")
int   cooldown    = input.int  (2,    "Cooldown Bars After Loss",     minval=0,  group="Risk")

// ── Calculations ──────────────────────────────────────────────────────────────
float atr = ta.atr(atrLen)
float minGapSize = atr * minGapAtr

[_dip, _dim, adxVal] = ta.dmi(adxLen, adxLen)
bool ranging = adxVal < adxMax

// ── FVG Detection (no lookahead — all on confirmed bars) ──────────────────────
//
//  Bullish FVG:  bar[2].high  <  bar[0].low   (gap in upward move)
//                bar[1] is the impulse candle between them
//
//  Bearish FVG:  bar[2].low   >  bar[0].high  (gap in downward move)
//
// We detect these on bar close (bar[0] = current confirmed bar)

bool bullFvgFormed = (low  - high[2]) >= minGapSize   // gap above bar[2]
bool bearFvgFormed = (low[2] - high)  >= minGapSize   // gap below bar[2]

// Store the most recent active FVG zone
var float bFvgTop    = na   // bullish FVG zone top    = bar[0].low  at formation
var float bFvgBot    = na   // bullish FVG zone bottom = bar[2].high at formation
var int   bFvgAge    = int(na)   // bar_index when formed

var float rFvgTop    = na   // bearish FVG zone top    = bar[2].low  at formation
var float rFvgBot    = na   // bearish FVG zone bottom = bar[0].high at formation
var int   rFvgAge    = int(na)

// Register new zones (only when flat to avoid overwriting mid-trade)
if bullFvgFormed and strategy.position_size == 0
    bFvgTop := low
    bFvgBot := high[2]
    bFvgAge := bar_index

if bearFvgFormed and strategy.position_size == 0
    rFvgTop := low[2]
    rFvgBot := high
    rFvgAge := bar_index

// Freshness check
bool bFvgFresh = not na(bFvgAge) and (bar_index - bFvgAge) <= lookback
bool rFvgFresh = not na(rFvgAge) and (bar_index - rFvgAge) <= lookback

// Price has returned into the zone
bool inBullZone = not na(bFvgBot) and close >= bFvgBot and close <= bFvgTop and bFvgFresh
bool inBearZone = not na(rFvgBot) and close <= rFvgTop and close >= rFvgBot and rFvgFresh

// Cooldown — fixed deadlock bug (see MR-03 changelog for full explanation)
var int _lastCount04    = 0
var int barsSinceLoss   = 999
if strategy.closedtrades > _lastCount04
    if strategy.closedtrades.profit(strategy.closedtrades - 1) < 0
        barsSinceLoss := 0
    _lastCount04 := strategy.closedtrades
barsSinceLoss := math.min(barsSinceLoss + 1, 9999)
bool cooledDown = barsSinceLoss > cooldown

// ── Entry Signals ─────────────────────────────────────────────────────────────
// Price returns into bull FVG → long (expect continuation up after fill)
bool longSig  = inBullZone and ranging and cooledDown
// Price returns into bear FVG → short (expect continuation down after fill)
bool shortSig = inBearZone and ranging and cooledDown

// Bar counter for time exit
var int barsHeld = 0
if strategy.position_size != 0
    barsHeld += 1
else
    barsHeld := 0

// ── Orders ────────────────────────────────────────────────────────────────────
if longSig and strategy.position_size == 0
    float gapSize = bFvgTop - bFvgBot
    strategy.entry("L", strategy.long)
    strategy.exit("L-exit", "L",
                  stop  = bFvgBot - slMult * gapSize,   // SL = below zone by N x gap (default 1.0 = symmetric)
                  limit = bFvgTop + gapSize)            // TP = gap size above zone top
    bFvgBot := na
    bFvgTop := na

if shortSig and strategy.position_size == 0
    float gapSize = rFvgTop - rFvgBot
    strategy.entry("S", strategy.short)
    strategy.exit("S-exit", "S",
                  stop  = rFvgTop + slMult * gapSize,   // SL = above zone by N x gap (default 1.0 = symmetric)
                  limit = rFvgBot - gapSize)            // TP = gap size below zone bottom
    rFvgBot := na
    rFvgTop := na

// Time stop
if strategy.position_size != 0 and barsHeld >= maxBars
    strategy.close_all(comment="Time")

// ── Visuals ───────────────────────────────────────────────────────────────────
// Show active FVG zones as boxes
var box bBox = box(na)
var box rBox = box(na)

if bullFvgFormed
    if not na(bBox)
        box.delete(bBox)
    bBox := box.new(bar_index[2], bFvgTop, bar_index + lookback, bFvgBot, border_color=color.new(color.green, 60), bgcolor=color.new(color.green, 88))

if bearFvgFormed
    if not na(rBox)
        box.delete(rBox)
    rBox := box.new(bar_index[2], rFvgTop, bar_index + lookback, rFvgBot, border_color=color.new(color.red, 60), bgcolor=color.new(color.red, 88))

plotshape(longSig,  title="Long",  style=shape.triangleup,   location=location.belowbar, color=color.green, size=size.small)
plotshape(shortSig, title="Short", style=shape.triangledown, location=location.abovebar, color=color.red,   size=size.small)
