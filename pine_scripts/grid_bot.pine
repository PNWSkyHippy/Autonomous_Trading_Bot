//@version=5
strategy("Grid Bot (BB Range + ADX)", shorttitle="GridBot", overlay=true, pyramiding=0, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=10, commission_type=strategy.commission.percent, commission_value=0.05, currency=currency.USD)

// Inputs
adx_period  = input.int(14,    title="ADX Period",       group="ADX")
adx_max     = input.float(15.0, title="ADX Max",         group="ADX", step=0.5)
bb_period   = input.int(20,    title="BB Period",        group="BB")
bb_std      = input.float(2.0, title="BB Std Dev",       group="BB", step=0.1)
long_edge   = input.float(0.20, title="Long Edge <=",    group="BB", step=0.01)
short_edge  = input.float(0.80, title="Short Edge >=",   group="BB", step=0.01)
sl_pct      = input.float(0.8, title="Stop Loss %",      group="SL/TP", step=0.1)
tp_pct      = input.float(1.5, title="Take Profit %",    group="SL/TP", step=0.1)
trade_longs = input.bool(true,  title="Longs",           group="Direction")
allow_shorts= input.bool(false, title="Shorts",          group="Direction")

// Indicators
adx_val = ta.dmi(adx_period, adx_period)
[bb_upper, bb_mid, bb_lower] = ta.bb(close, bb_period, bb_std)
band_range   = bb_upper - bb_lower
position_pct = band_range > 0 ? (close - bb_lower) / band_range : 0.5

// Signals
is_ranging   = adx_val <= adx_max
near_lower   = position_pct <= long_edge
near_upper   = position_pct >= short_edge
long_signal  = is_ranging and near_lower and trade_longs  and strategy.position_size == 0
short_signal = is_ranging and near_upper and allow_shorts and strategy.position_size == 0

// Entries
if long_signal
    strategy.entry("Long", strategy.long)
    strategy.exit("LX", "Long", stop=close*(1-sl_pct/100), limit=close*(1+tp_pct/100))

if short_signal
    strategy.entry("Short", strategy.short)
    strategy.exit("SX", "Short", stop=close*(1+sl_pct/100), limit=close*(1-tp_pct/100))

// Plots
plot(bb_upper, color=color.new(color.blue, 60))
plot(bb_mid,   color=color.new(color.gray, 60))
plot(bb_lower, color=color.new(color.blue, 60))
plotshape(long_signal,  style=shape.triangleup,   location=location.belowbar, color=color.lime, size=size.small)
plotshape(short_signal, style=shape.triangledown, location=location.abovebar, color=color.red,  size=size.small)
