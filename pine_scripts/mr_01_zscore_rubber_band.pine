//@version=5
// ─────────────────────────────────────────────────────────────────────────────
// MR-01  Z-Score Rubber Band
// ─────────────────────────────────────────────────────────────────────────────
// Hypothesis:
//   When price stretches far from its recent mean (z-score extreme) AND
//   the market is in a ranging regime (low ADX) AND volume is declining
//   (no conviction behind the move), price will snap back to the mean.
//
// Why this is NOT a retail strategy:
//   Uses z-score normalisation (statistically-grounded distance measure)
//   rather than raw indicator levels. Volume dry-up filter adds a second
//   independent confirmation axis. Works long AND short.
//
// Edge: Price rubber-bands from over-extension during low-volatility regimes.
// ─────────────────────────────────────────────────────────────────────────────
strategy("MR-01 Z-Score Rubber Band", shorttitle="MR-01 ZSRB", overlay=true,
         default_qty_type  = strategy.percent_of_equity,
         default_qty_value = 10,
         commission_type   = strategy.commission.percent,
         commission_value  = 0.05,
         slippage          = 2)

// ── Inputs ────────────────────────────────────────────────────────────────────
int   zLen     = input.int  (20,  "Z-Score Period",           minval=5,  group="Mean Reversion")
float zEntry   = input.float(2.0, "Z-Score Entry Threshold",  step=0.1,  group="Mean Reversion")
float zExit    = input.float(0.5, "Z-Score Exit Threshold",   step=0.1,  group="Mean Reversion")
int   adxLen   = input.int  (14,  "ADX Period",               minval=5,  group="Regime Filter")
float adxMax   = input.float(30,  "ADX Max (ranging only)",   step=1.0,  group="Regime Filter")
int   volLen   = input.int  (20,  "Volume MA Period",         minval=5,  group="Volume Filter")
float volRatio = input.float(0.8, "Volume Ratio (< = weak)",  step=0.05, group="Volume Filter")
int   atrLen   = input.int  (14,  "ATR Period",               minval=5,  group="Risk")
float slMult   = input.float(2.0, "Stop Loss ATR Mult",       step=0.1,  group="Risk")
float tpMult   = input.float(2.0, "Take Profit ATR Mult",     step=0.1,  group="Risk")
int   cooldown = input.int  (3,   "Cooldown Bars After Loss", minval=0,  group="Risk")

// ── Calculations ──────────────────────────────────────────────────────────────
float mean   = ta.sma  (close, zLen)
float stdDev = ta.stdev(close, zLen)
float zScore = stdDev > 0 ? (close - mean) / stdDev : 0.0

float atr    = ta.atr(atrLen)
[_diPlus, _diMinus, adxVal] = ta.dmi(adxLen, adxLen)
bool ranging = adxVal < adxMax

float volMa  = ta.sma(volume, volLen)
bool volWeak = volume < volMa * volRatio   // declining participation

// Cooldown counter — reset on any losing trade
// FIX v2: old pattern re-checked last-trade profit every bar → permanent deadlock
// after any loss. Now tracks closedtrades count; only updates on new close.
var int _lastCount01    = 0
var int barsSinceLoss   = 999   // large = immediately cooled down at start
if strategy.closedtrades > _lastCount01
    if strategy.closedtrades.profit(strategy.closedtrades - 1) < 0
        barsSinceLoss := 0
    _lastCount01 := strategy.closedtrades
barsSinceLoss := math.min(barsSinceLoss + 1, 9999)
bool cooledDown = barsSinceLoss > cooldown

// ── Entry Signals ─────────────────────────────────────────────────────────────
bool longSig  = zScore < -zEntry and ranging and volWeak and cooledDown
bool shortSig = zScore >  zEntry and ranging and volWeak and cooledDown

// ── Orders ────────────────────────────────────────────────────────────────────
if longSig and strategy.position_size == 0
    strategy.entry("L", strategy.long)
    strategy.exit ("L-exit", "L",
                   stop  = close - slMult * atr,
                   limit = close + tpMult * atr)

if shortSig and strategy.position_size == 0
    strategy.entry("S", strategy.short)
    strategy.exit ("S-exit", "S",
                   stop  = close + slMult * atr,
                   limit = close - tpMult * atr)

// Mean-reversion exit: close when z-score returns to neutral
if strategy.position_size > 0 and zScore > -zExit
    strategy.close("L", comment="Z-mean")
if strategy.position_size < 0 and zScore <  zExit
    strategy.close("S", comment="Z-mean")

// ── Visuals ───────────────────────────────────────────────────────────────────
plot(mean,                    "Mean",        color=color.gray,  linewidth=1)
plot(mean + zEntry * stdDev,  "Upper (+2σ)", color=color.red,   linewidth=1)
plot(mean - zEntry * stdDev,  "Lower (-2σ)", color=color.green, linewidth=1)
plotshape(longSig,  title="Long",  style=shape.triangleup,   location=location.belowbar, color=color.green, size=size.small)
plotshape(shortSig, title="Short", style=shape.triangledown, location=location.abovebar, color=color.red,   size=size.small)
