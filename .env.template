# =============================================================================
# Trading Bot V2 — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git — it is gitignored.
# Use _. env.pgp (PGP encrypted) for secure cloud backup of your actual .env
#
# Usage:
#   cp .env.template .env
#   # Edit .env with your actual credentials
# =============================================================================


# =============================================================================
# ALPACA — Stock paper/live trading
# Paper:  https://app.alpaca.markets/paper-trading/overview
# Live:   https://app.alpaca.markets/live-trading/overview
# =============================================================================
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Paper trading endpoint (use this until going live)
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Live trading endpoint (switch when funded and ready)
# ALPACA_BASE_URL=https://api.alpaca.markets


# =============================================================================
# KRAKEN — Crypto trading (paper mode simulated locally — no sandbox API)
# API keys: https://www.kraken.com/u/security/api
# Required scopes: Query Funds, Query Open Orders, Query Closed Orders,
#                  Create & Modify Orders, Cancel/Close Orders
# =============================================================================
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_SECRET_KEY=your_kraken_secret_key_here


# =============================================================================
# COINBASE — Legacy (deprecated, Kraken used instead)
# These keys are no longer active — CoinbaseExecutor internally uses Kraken.
# Leave blank unless specifically re-enabling Coinbase integration.
# =============================================================================
COINBASE_API_KEY=
COINBASE_SECRET_KEY=


# =============================================================================
# INTERACTIVE BROKERS (IBKR) — Optional stock broker
# Requires TWS or IB Gateway running on localhost.
# Paper port: 7497 | Live port: 7496
# Account ID found in TWS: Account menu → Account Summary
# Recommended: Use IBC for headless auto-login (see Scripts/IBC_SETUP.md)
# =============================================================================
IBKR_ACCOUNT=your_ibkr_account_id_here


# =============================================================================
# ANTHROPIC — Claude AI for signal review and chat interface
# API keys: https://console.anthropic.com/settings/keys
# Required for: morning briefing, per-signal review, dashboard chat commands
# Model used: claude-haiku (fast, low cost for trade review)
# =============================================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here


# =============================================================================
# EMAIL — Daily reports and trade alerts
# Uses Gmail SMTP with App Password (NOT your main Gmail password)
# Setup: https://myaccount.google.com/apppasswords
# Enable 2FA first, then generate an App Password for "Mail"
# =============================================================================
EMAIL_SENDER=your_gmail_address@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_here
EMAIL_RECIPIENT=address_to_receive_reports@gmail.com


# =============================================================================
# SMS — Optional trade alerts via carrier email-to-SMS gateway
# Format: {10_digit_phone}@{carrier_gateway}
# Common gateways:
#   Verizon:   @vtext.com
#   AT&T:      @txt.att.net
#   T-Mobile:  @tmomail.net
#   Sprint:    @messaging.sprintpcs.com
# Example: 2065551234@vtext.com
# Leave blank to disable SMS alerts
# =============================================================================
SMS_RECIPIENT=


# =============================================================================
# ALERT DIGEST — Controls email batching (also configurable in config.py)
# Overrides config.py ALERT_DIGEST_HOURS if set here
# 0 = one email per trade (old behavior)
# 1 = hourly digest (default)
# 2 = every 2 hours
# Leave blank to use config.py setting
# =============================================================================
# ALERT_DIGEST_HOURS=1


# =============================================================================
# OPTIONAL OVERRIDES — Advanced settings (normally set in config.py)
# Uncomment and set only if you need per-environment overrides
# =============================================================================

# Override max position size % (default: 2.0)
# MAX_POSITION_PCT=2.0

# Override daily loss halt threshold % (default: 15.0)
# MAX_DAILY_LOSS_PCT=15.0

# Override minimum signal confidence (default: 0.65)
# MIN_SIGNAL_CONFIDENCE=0.65

# Alert on trade open (default: true)
# ALERT_ON_TRADE_OPEN=true

# Alert on trade close (default: true)
# ALERT_ON_TRADE_CLOSE=true

# Alert on trading halt (default: true)
# ALERT_ON_HALT=true

# Minimum P&L to trigger close alert in dollars (default: 0)
# ALERT_MIN_PNL=0
